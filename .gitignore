.claude/
# makepkg build artifacts (created inside each package dir)
*.pkg.tar.*
*.src.tar.*
src/
pkg/
# ...but the Rust updater keeps its sources under aur-updater/src/
!aur-updater/src/

# Editors / OS
*.swp
.DS_Store

# AUR updater
aur-updater/target/
# Telegram secrets (never committed)
aur-updater/*.env
aur-updater/**/*.env
